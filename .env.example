# ── Gemini AI ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Vector Store ────────────────────────────────────────────────────────────────
# "chroma" for local dev, "pinecone" for production
VECTOR_STORE=chroma

PINECONE_API_KEY=
PINECONE_INDEX_NAME=documind-prod
PINECONE_ENVIRONMENT=us-east-1

# ── Database ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://documind:documind_pass@localhost:5432/documind

# ── Redis ───────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Chroma (local dev) ──────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── Auth ────────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AWS S3 ──────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=documind-uploads
AWS_REGION=us-east-1
# Set to "local" to use local disk storage instead of S3
STORAGE_BACKEND=local

# ── CORS ────────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Rate Limiting ────────────────────────────────────────────────────────────────
RATE_LIMIT_QUERIES_PER_MIN=20
RATE_LIMIT_UPLOADS_PER_HOUR=5
MAX_UPLOAD_SIZE_MB=50

# ── Frontend ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
